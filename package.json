{
  "name": "opus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "web": "sh scripts/dev-web-open.sh",
    "db:generate": "pnpm --filter @opus/web run db:generate",
    "db:migrate": "pnpm --filter @opus/web run db:migrate",
    "db:deploy": "pnpm --filter @opus/web run db:deploy",
    "db:validate": "pnpm --filter @opus/web run db:validate",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@opus/config": "workspace:*",
    "eslint": "^9.39.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0"
    }
  }
}
