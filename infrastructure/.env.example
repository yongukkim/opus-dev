# Mac Mini (The Vault) — copy to `infrastructure/.env`. Do not commit `.env`.
# SECURITY_GOVERNANCE.md: production → GCP Secret Manager; this file is a template only.

# --- PostgreSQL 17 (The Chronicle / OPUS) ---
POSTGRES_USER=opus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=opus_chronicle
# Published port (Tailscale/LAN clients e.g. MacBook Air)
POSTGRES_PORT=5432

# --- PgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PGADMIN_PORT=5050
