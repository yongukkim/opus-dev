# Copy to .env on the server (Mac Mini). Do not commit .env.
# SECURITY_GOVERNANCE.md: production secrets → GCP Secret Manager; local .env is dev-only.

# --- PostgreSQL 17 (The Chronicle / OPUS) ---
POSTGRES_USER=opus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=opus_chronicle
# Host port published for Tailscale/LAN clients (MacBook Air, etc.)
POSTGRES_PORT=5432

# --- PgAdmin (web UI; restrict network per governance) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PGADMIN_PORT=5050
