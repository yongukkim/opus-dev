# OPUS — Local development placeholders only.
# Production: load secrets from GCP Secret Manager (SECURITY_GOVERNANCE.md). Do not commit real values.

# Public URL only when unavoidable; never put secrets in NEXT_PUBLIC_*.
# NEXT_PUBLIC_APP_URL=https://example.com

# Server-only (inject via Secret Manager / runtime env in deployment)
# API_SECRET=
# Prisma (`prisma/schema.prisma` at repo root) — PostgreSQL 17 on The Vault / Docker per infra docs
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# apps/mobile — Expo (`expo start` / `pnpm mobile:web`). Google Cloud OAuth 2.0 client IDs.
# Web preview: "Web application" client; add Authorized redirect URI exactly as sent (usually http://localhost:8081 — no opus:// scheme).
# Optional override if Google Console URI must match exactly: EXPO_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:8081
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# 로컬에서 Expo 웹 로그인까지 테스트: Next(dev)를 켠 뒤 같은 호스트로 맞춤 (예: http://localhost:3000).
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_API_URL=https://app.opus-store.com
#
# apps/web — server exchanges Google auth code for mobile web (AUTH_GOOGLE_* must match EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID).
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
