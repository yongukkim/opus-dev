# OPUS — Local development placeholders only.
# Production: load secrets from GCP Secret Manager (SECURITY_GOVERNANCE.md). Do not commit real values.

# Public URL only when unavoidable; never put secrets in NEXT_PUBLIC_*.
# NEXT_PUBLIC_APP_URL=https://example.com

# Server-only (inject via Secret Manager / runtime env in deployment)
# API_SECRET=
# Prisma (`prisma/schema.prisma` at repo root) — PostgreSQL 17 on The Vault / Docker per infra docs
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
