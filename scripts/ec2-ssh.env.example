# Copy to scripts/ec2-ssh.env (never commit). chmod 600 scripts/ec2-ssh.env
#
# ISO 27001 A.9.4.2 / A.13.1.3 — SSH identity is a secret; keep this file out of VCS.
# KO: EC2 접속용 키 경로·호스트는 이 파일에만 두고 Git에 올리지 않는다.
# JA: EC2接続用の鍵パス・ホストは本ファイルのみに置き、Gitに載せない。
# EN: Keep EC2 SSH host and key path in this file only; never commit it.

OPUS_EC2_USER=ubuntu
OPUS_EC2_HOST=ec2-xx-xx-xx-xx.ap-northeast-1.compute.amazonaws.com
OPUS_EC2_IDENTITY_FILE=/absolute/path/to/your-key.pem
