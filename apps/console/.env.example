# Copy to `.env` (never commit). Use the same DATABASE_URL and AUTH_SECRET strategy as apps/web.

# Auth.js canonical URL for CSRF / verification links (`compose.web.yaml` sets AUTH_URL for EC2 console host).
# AUTH_URL=https://console.opus-store.com

# Development only: skip sign-in and open /[locale]/review with sample rows (NODE_ENV must be development).
# OPUS_CONSOLE_DEV_PREVIEW=1

# Registration is invite-only: `/{ja|ko|en}/register?invite=<this value>` (share the full URL with operators only).
# OPUS_CONSOLE_REGISTER_SECRET=

# DATABASE_URL=postgresql://...

# Auth.js — AUTH_SECRET required (same as web). Used to sign JWT session cookies.
# AUTH_SECRET=

# Outbound email for registration verification (production: both required). Local dev without SMTP logs the link to the server console.
# CONSOLE_SMTP_URL=smtps://user:pass@smtp.example.com:465
# CONSOLE_MAIL_FROM="OPUS Console <noreply@example.com>"

# Public storefront origin (footer link only)
# OPUS_STORE_PUBLIC_ORIGIN=https://app.opus-store.com

# Storefront base URL for server-to-server internal APIs (no trailing slash)
# OPUS_WEB_ORIGIN=https://app.opus-store.com

# Must match apps/web OPUS_INTERNAL_API_SECRET (long random)
# OPUS_INTERNAL_API_SECRET=
