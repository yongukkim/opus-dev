# Copy to `.env` (never commit). Use the same DATABASE_URL and AUTH_SECRET strategy as apps/web.

# Production on console.*: if the host shares one env file with the web app, set Auth.js canonical URL here
# so OAuth callback / CSRF cookies are not pinned to the storefront (`compose.web.yaml` sets this for EC2).
# AUTH_URL=https://console.opus-store.com

# Development only: skip OAuth and open /review with sample rows (NODE_ENV must be development).
# OPUS_CONSOLE_DEV_PREVIEW=1

# DATABASE_URL=postgresql://...

# Auth.js — AUTH_SECRET required (same as web). Google OAuth uses the same consent cookie rules as the storefront.
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# In Google Cloud Console, add authorized redirect: https://console.opus-store.com/api/auth/callback/google

# Public storefront origin (links + OAuth consent error redirect)
# OPUS_STORE_PUBLIC_ORIGIN=https://app.opus-store.com

# Storefront base URL for server-to-server internal APIs (no trailing slash)
# OPUS_WEB_ORIGIN=https://app.opus-store.com

# Must match apps/web OPUS_INTERNAL_API_SECRET (long random)
# OPUS_INTERNAL_API_SECRET=
