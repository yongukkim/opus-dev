{
  "name": "@opus/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "dev:fixed": "next dev --turbopack -p 4321",
    "dev:report": "sh -c '(sleep 5 && sh ../../infrastructure/scripts/notify.sh) & exec next dev --turbopack'",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:validate": "prisma validate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@opus/api": "workspace:*",
    "@opus/ui": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.67.2",
    "cmdk": "^1.1.1",
    "next": "^16.2.1",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.1",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@opus/config": "workspace:*",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
