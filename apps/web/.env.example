# Copy to `.env` (never commit). Production: prefer GCP Secret Manager (SECURITY_GOVERNANCE.md).

# Dedicated operator console (public URL for redirects from the storefront). Dev default: http://localhost:3010
# NEXT_PUBLIC_OPUS_CONSOLE_ORIGIN=https://console.opus-store.com

# Shared secret for the dedicated operator console app (server-to-server only). Generate a long random value.
# OPUS_INTERNAL_API_SECRET=

# Slack Incoming Webhook for local/dev notifications (notify.sh)
# SLACK_WEBHOOK_URL=

# UI-only list price conversion from integer JPY (registration basis). Not a settlement quote.
# OPUS_DISPLAY_KRW_PER_JPY=9.15
# OPUS_DISPLAY_JPY_PER_USD=149

# When "true", demo checkout (releases with fromSubmission) records JSONL custody on /purchase/success
# for collectors — no KOMOJU. Never enable on public production without operator approval.
# OPUS_DEMO_PRIMARY_PURCHASE=false

# --- KOMOJU (hosted checkout / webhooks; keys via Secret Manager in production) ---
# KOMOJU_SECRET_KEY=
# KOMOJU_PUBLISHABLE_KEY=
# KOMOJU_WEBHOOK_SECRET=
# If reverse-proxy Host/proto is wrong for return URLs:
# OPUS_PUBLIC_APP_URL=https://www.example.com

# --- Auth.js (storefront Google OAuth) ---
# Production EC2: compose.web.yaml pins AUTH_URL via AUTH_URL_WEB (defaults to https://app.opus-store.com).
# Local docker compose: export AUTH_URL_WEB=http://localhost:3000 before `docker compose -f compose.web.yaml up`.
# AUTH_SECRET=
#
# Storefront JWT session max lifetime (seconds). Default 28800 (8h). Min 300, max 2592000 (30d).
# OPUS_WEB_SESSION_MAX_AGE_SECONDS=28800
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
#
# Apple Sign In (Services ID + JWT client secret from Apple Developer — see Auth.js Apple provider docs).
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=
#
# LINE Login (OpenID). Prefer AUTH_LINE_*; LINE_LOGIN_CHANNEL_* is accepted as an alias.
# Callback: {AUTH_URL}/api/auth/callback/line
# AUTH_LINE_ID=
# AUTH_LINE_SECRET=
# LINE_LOGIN_CHANNEL_ID=
# LINE_LOGIN_CHANNEL_SECRET=
#
# Email verification (storefront register). Production needs one of:
#   (A) Resend — HTTPS only. API key: `OPUS_WEB_RESEND_API_KEY` (preferred) or `RESEND_API_KEY`.
# OPUS_WEB_RESEND_API_KEY=re_...
# OPUS_WEB_MAIL_FROM="OPUS <onboarding@resend.dev>"
#   (B) SMTP — traditional relay.
# OPUS_WEB_SMTP_URL=smtps://user:pass@smtp.example.com:465
# OPUS_WEB_MAIL_FROM="OPUS <noreply@example.com>"
# OPUS_WEB_PUBLIC_ORIGIN=https://app.opus-store.com

