# OPUS edge — storefront only (app.opus-store.com). Operator console runs on a separate EC2 + Caddyfile.console.
#
# ISO 27001 A.10.1.1 / A.13.1.3 (CLAUDE.md §3, §6)
# KO: 공개 스토어와 운영 콘솔의 TLS·프로세스 경계를 호스트 단에서 분리한다.
# JA: 公開ストアと運用コンソールのTLS・プロセス境界をホスト単位で分離する。
# EN: Split TLS/process boundary between storefront and operator console at the host level.

{
	email admin@opus-store.com
}

app.opus-store.com {
	encode zstd gzip

	reverse_proxy opus-web:3000

	log {
		output stderr
		format console
	}
}
