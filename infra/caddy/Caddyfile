# OPUS edge — Caddy 2 reverse proxy with automatic HTTPS (Let's Encrypt).
#
# ISO 27001 A.10.1.1 / A.13.1.3 / A.18.1.4 (CLAUDE.md §3, §6, §7)
# KO: 외부 트래픽은 모두 TLS 1.3로 종단되며, 80은 ACME 챌린지와 443 리다이렉트로만 쓴다.
#     Auth.js 보안 쿠키와 APPI 동의 쿠키가 secure 플래그 아래에서 정상 동작하기 위한 전제다.
# JA: 外部トラフィックは全てTLS 1.3で終端し、80はACMEチャレンジと443へのリダイレクトのみに使用する。
#     Auth.jsのセキュアCookieとAPPI同意CookieがsecureフラグでiPad正常に動作する前提条件。
# EN: All public traffic terminates at TLS 1.3 here; port 80 is reserved for ACME challenges and the
#     redirect to 443. This is the precondition for Auth.js secure cookies and the APPI consent cookie.

{
	# Let's Encrypt account email — 인증서 만료 임박/실패 시 알림 수신용. opus-store.com 어드민 메일.
	email admin@opus-store.com
}

# ISO 27001 A.10.1.1 (§3) — Single site block lists both public names so one LE cert carries SANs for app + console.
# KO: app·console을 한 블록에 두면 SNI/인증서 발급이 호스트별로 어긋나 TLS 핸드셰이크가 끊기는 경우를 줄인다.
# JA: app·console を同一ブロックに置くとSNI/証明書発行のずれでTLSが切れる事象を減らす。
# EN: Listing app and console in one site block reduces TLS handshake gaps when per-host cert issuance drifts.
app.opus-store.com, console.opus-store.com {
	encode zstd gzip

	# Caddy는 기본적으로 X-Forwarded-{Proto,Host,For,Port} 헤더를 upstream에 자동 부여한다 →
	# Auth.js의 trustHost(=true)와 함께 secure cookie / callback URL 도출이 정상 동작한다.
	@app host app.opus-store.com
	handle @app {
		reverse_proxy opus-web:3000
	}

	# Operator console — Next.js `opus-console` (Dockerfile.console). OTP + optional Google OAuth.
	@con host console.opus-store.com
	handle @con {
		reverse_proxy opus-console:3010
	}

	# HSTS preload 후보지만 운영 도메인 확정 + www 합류 후 별도 PR로 켠다.
	# header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	log {
		output stderr
		format console
	}
}
