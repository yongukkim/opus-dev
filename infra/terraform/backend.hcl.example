# Copy to `backend.hcl` (gitignored) and replace placeholders. Do not commit real bucket names if they reveal env.
#
# Create the bucket once (global name; example uses ap-northeast-1):
#   aws s3api create-bucket --bucket YOUR_UNIQUE_BUCKET_NAME \
#     --region ap-northeast-1 \
#     --create-bucket-configuration LocationConstraint=ap-northeast-1
#   aws s3api put-bucket-versioning --bucket YOUR_UNIQUE_BUCKET_NAME \
#     --versioning-configuration Status=Enabled
#
# Optional state locking (recommended for team apply):
#   aws dynamodb create-table --table-name opus-terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region ap-northeast-1

bucket  = "REPLACE_WITH_GLOBALLY_UNIQUE_STATE_BUCKET"
key     = "opus/terraform.tfstate"
region  = "ap-northeast-1"
encrypt = true
# dynamodb_table = "opus-terraform-locks"
