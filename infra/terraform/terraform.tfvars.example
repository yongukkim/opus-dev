# Copy to terraform.tfvars (gitignored).
# ssh_public_key: one line, full output of `cat ~/.ssh/id_rsa.pub`.

ssh_public_key = "REPLACE_WITH_YOUR_PUBLIC_KEY"

# 앱 EC2 타입 (기본 t4g.small — micro 에서 Docker 빌드가 버거우면 유지).
# app_instance_type = "t4g.micro"

# 운영 콘솔 전용 EC2 (기본 t4g.nano — 최소 사양; RDS는 앱과 동일 VPC·SG 규칙으로 공유).
# console_instance_type = "t4g.nano"

# RDS (PostgreSQL) — 기본 off. true 로 바꾸면 private subnet·SG·인스턴스가 함께 만들어진다.
# enable_rds           = true
# db_name              = "opus"
# db_username          = "opus"
# db_instance_class    = "db.t4g.micro"
# db_allocated_storage = 20
# ap-northeast-1 에서 사용 가능한 버전으로 pin (variables.tf 기본값과 맞출 것).
# db_engine_version    = "16.13"
